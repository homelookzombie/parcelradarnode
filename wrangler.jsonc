{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "parcelradarnode",
  "main": "worker.mjs",
  "compatibility_date": "2026-05-02",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/health*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
